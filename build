#!/usr/bin/env bash

NIX_ARGS=()
AI_NIX_DIR=${AI_NIX_DIR:-$HOME/src/ai-nix}
if [[ -z ${NO_AI_NIX_OVERRIDE:-} && -f $AI_NIX_DIR/flake.nix ]]; then
    NIX_ARGS+=(--override-input ai-nix "$AI_NIX_DIR")
fi

if [[ $1 == system ]]; then
    shift 1
    nix build --max-jobs 8 --cores 8 \
        ".#darwinConfigurations.$(myhost).system" \
        "${NIX_ARGS[@]}" "$@" --keep-going --show-trace
elif [[ $1 == pkg ]]; then
    pkg=$2
    shift 2
    nix build --cores 24 ".#darwinConfigurations.$(myhost).pkgs.$pkg" \
        "${NIX_ARGS[@]}" "$@"
elif [[ $1 == emacs ]]; then
    pkg=$2
    shift 2
    nix build --cores 24 ".#darwinConfigurations.$(myhost).pkgs.emacs30MacPortPackages.$pkg" \
        "${NIX_ARGS[@]}" "$@"
elif [[ $1 == python ]]; then
    pkg=$2
    shift 2
    nix build --cores 24 ".#darwinConfigurations.$(myhost).pkgs.python3Packages.$pkg" \
        "${NIX_ARGS[@]}" "$@"
elif [[ $1 == haskell ]]; then
    pkg=$2
    shift 2
    nix build --cores 24 ".#darwinConfigurations.$(myhost).pkgs.haskellPackages.$pkg" \
        "${NIX_ARGS[@]}" "$@"
fi
