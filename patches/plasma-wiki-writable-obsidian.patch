+def _make_writable(path: pathlib.Path) -> None:
+    """Make copied Obsidian files writable without following symlinks."""
+    if not path.exists():
+        return
+    for entry in (path, *path.rglob('*')):
+        if entry.is_symlink():
+            continue
+        entry.chmod(entry.stat().st_mode | 0o200)
