+# Emit a correlated error only for requests carrying a non-null id.
+# Notifications remain silent.  The data object makes the at-most-once
+# boundary explicit to callers deciding whether a human should retry.
+anvil_mcp_synthetic_error() {
+	local request="$1"
+	local framed="$2"
+	local phase="$3"
+	local dispatched="$4"
+	local client_rc="$5"
+	local request_id message response
+
+	request_id=$(printf '%s' "$request" \
+		| sed -nE 's/.*"id"[[:space:]]*:[[:space:]]*([0-9]+|"[^"]*"|null).*/\1/p' \
+		| head -1)
+	if [ -z "$request_id" ] || [ "$request_id" = "null" ]; then
+		return 0
+	fi
+	case "$phase" in
+	readiness) message="daemon readiness probe failed before dispatch" ;;
+	*) message="daemon response was ambiguous after one dispatch" ;;
+	esac
+	response=$(printf '{"jsonrpc":"2.0","id":%s,"error":{"code":-32603,"message":"Bridge synthetic error: %s","data":{"phase":"%s","dispatched":%s,"replayed":false,"emacsclientRc":%s}}}' \
+		"$request_id" "$message" "$phase" "$dispatched" "$client_rc")
+	mcp_debug_log "SYNTH-ERROR" "id=$request_id phase=$phase dispatched=$dispatched replayed=false rc=$client_rc"
+	anvil_mcp_emit_response "$framed" "$response"
+}
