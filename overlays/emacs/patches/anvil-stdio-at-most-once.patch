+	exec 7<&- 9>&-
+	case "$input_mode:$stderr_mode" in
+	input:merge)
+		anvil_mcp_exec_program "$@" < <(printf '%s' "$input") 2>&1 8>&-
+		;;
+	input:separate)
+		anvil_mcp_exec_program "$@" < <(printf '%s' "$input") 2>&8 8>&-
+		;;
+	descriptor:merge)
+		anvil_mcp_exec_program "$@" <&5 5<&- 2>&1 8>&-
+		;;
+	descriptor:separate)
+		anvil_mcp_exec_program "$@" <&5 5<&- 2>&8 8>&-
+		;;
+	inherit:merge)
