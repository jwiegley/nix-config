Close stdin for host commands that cannot supply input.

The shell tool has no stdin parameter.  Leaving the pipe write end open makes
commands such as cat, grep, and rg-without-a-path wait until the tool timeout.

diff --git c/anvil-host.el w/anvil-host.el
index 67d14cb..bae3a32 100644
--- c/anvil-host.el
+++ w/anvil-host.el
@@ -127,6 +127,14 @@ buffers."
                    :sentinel #'ignore
                    :command
                    (list shell-file-name shell-command-switch command))))
+          ;; The shell API has no stdin channel.  Close the pipe immediately so
+          ;; commands that auto-read non-TTY stdin observe EOF instead of
+          ;; retaining the root event loop until the tool timeout.
+          (condition-case error
+              (process-send-eof proc)
+            (error
+             (when (process-live-p proc)
+               (signal (car error) (cdr error)))))
           ;; make-process represents stderr with an independent pipe process.
           ;; It needs its own sentinel and must be serviced separately.
           (setq stderr-proc (get-buffer-process stderr-buf))
