Expose async evaluation activity transitions for dedicated watchdogs.

The callbacks are inert by default, preserving interactive Emacs behavior.
Activation runs before evaluation and may prevent it; the idle transition is
protected by unwind-protect, and a dedicated backend may install a fail-closed
cleanup handler.

--- a/anvil-eval.el
+++ b/anvil-eval.el
@@ -260,6 +260,19 @@
 (defvar anvil-eval--async-counter 0
   "Counter for generating unique job IDs.")
 
+(defvar anvil-eval-async-active-function nil
+  "Optional function called with JOB-ID immediately before async evaluation.
+If it signals, the form is not evaluated and the job records an error.")
+
+(defvar anvil-eval-async-idle-function nil
+  "Optional function called with JOB-ID when async evaluation leaves activity.
+The transition runs from unwind-protect, including when evaluation signals.")
+
+(defvar anvil-eval-async-cleanup-failure-function nil
+  "Optional function called with JOB-ID and ERROR after an idle transition fails.
+A dedicated daemon can install a fail-closed handler.  Interactive Emacs leaves
+this nil so a transition bug records a failed job without killing the editor.")
+
 (defun anvil-eval--async (expression)
   "Evaluate EXPRESSION asynchronously via run-with-timer.
 Returns a job ID immediately.  The expression runs in the next
@@ -289,11 +302,37 @@
           (let ((job (gethash job-id anvil-eval--async-jobs)))
             (when job
               (let ((run-start (current-time))
-                    status result)
+                    status result activated cleanup-error)
                 (setq job (plist-put job :run-start-time run-start))
                 (condition-case err
-                    (setq result (format "%S" (eval form t))
-                          status 'done)
+                    (progn
+                      ;; Activation is outside the protected body: a failed
+                      ;; lease transition must prevent the form from running.
+                      (when anvil-eval-async-active-function
+                        (funcall anvil-eval-async-active-function job-id)
+                        (setq activated t))
+                      (unwind-protect
+                          (condition-case eval-error
+                              (setq result (format "%S" (eval form t))
+                                    status 'done)
+                            (error
+                             (setq result (format "Error: %S" eval-error)
+                                   status 'error)))
+                        (when (and activated
+                                   anvil-eval-async-idle-function)
+                          (condition-case idle-error
+                              (funcall anvil-eval-async-idle-function job-id)
+                            (error
+                             (setq cleanup-error idle-error)
+                             (when
+                                 anvil-eval-async-cleanup-failure-function
+                               (funcall
+                                anvil-eval-async-cleanup-failure-function
+                                job-id idle-error))))))
+                      ;; Interactive Emacs has no fail-closed handler.  Surface
+                      ;; cleanup failure as the job result in that backend.
+                      (when cleanup-error
+                        (signal (car cleanup-error) (cdr cleanup-error))))
                   (error
                    (setq result (format "Error: %S" err)
                          status 'error)))
