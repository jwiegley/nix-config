+         (isolated (plist-get keys :isolated))
+         (context-form (anvil-offload--bind-context form keys))
+         (full-form
+          (if preamble `(progn ,@preamble ,context-form) context-form))
+         (proc (if isolated
+                   (anvil-offload--spawn-isolated-process id)
+                 (anvil-offload--pick-worker)))
