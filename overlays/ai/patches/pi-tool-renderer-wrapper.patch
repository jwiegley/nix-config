diff --git i/dist/core/extensions/tool-renderers.js w/dist/core/extensions/tool-renderers.js
new file mode 100644
index 0000000..b7e4ea7
--- /dev/null
+++ w/dist/core/extensions/tool-renderers.js
@@ -0,0 +1,32 @@
+/**
+ * Apply extension renderer wrappers to a copy of a tool definition.
+ * Execution, schema, prompt metadata, and active state remain untouched.
+ */
+export function applyToolRendererWrappers(extensions, definition, inheritedDefinition, onError = () => {}) {
+    let renderers = {
+        renderShell: definition.renderShell ?? inheritedDefinition?.renderShell,
+        renderCall: definition.renderCall ?? inheritedDefinition?.renderCall,
+        renderResult: definition.renderResult ?? inheritedDefinition?.renderResult,
+    };
+    const tool = { name: definition.name, label: definition.label };
+    for (const extension of extensions) {
+        for (const wrapper of extension.toolRenderers ?? []) {
+            try {
+                const wrapped = wrapper(tool, renderers);
+                if (!wrapped || typeof wrapped !== "object") {
+                    throw new TypeError("Tool renderer wrapper must return a renderer object");
+                }
+                renderers = { ...renderers, ...wrapped };
+            }
+            catch (error) {
+                onError({
+                    extensionPath: extension.path,
+                    event: "tool_renderer",
+                    error: error instanceof Error ? error.message : String(error),
+                    stack: error instanceof Error ? error.stack : undefined,
+                });
+            }
+        }
+    }
+    return { ...definition, ...renderers };
+}
