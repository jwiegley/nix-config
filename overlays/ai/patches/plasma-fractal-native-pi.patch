diff --git a/fractal/impl/pi.py b/fractal/impl/pi.py
new file mode 100644
index 0000000..b740193
--- /dev/null
+++ b/fractal/impl/pi.py
@@ -0,0 +1,86 @@
+"""Pi coding-agent CLI implementation."""
+
+from __future__ import annotations
+
+import pathlib
+from typing import Optional
+
+from fractal.core.agent import Agent, Invocation
+from fractal.impl.omp import OmpParser
+
+__all__ = [
+    'PiParser',
+    'PiAgent',
+]
+
+
+class PiParser(OmpParser):
+    """Parser for Pi ``--mode json`` output."""
+
+
+class PiAgent(Agent):
+    """Pi CLI backend with isolated sessions and explicit node skills."""
+
+    name = 'pi'
+    config_file = ''
+    can_fork = True
+    mints_session = True
+    needs_pricing = False
+    cost_scope = 'call'
+    enforces_budget = False
+    providers = ()
+
+    __parser__ = PiParser
+
+    def _invocation(
+        self: PiAgent,
+        prompt: str,
+        *,
+        mode: str,
+        session: Optional[str],
+        model: Optional[str],
+        effort: Optional[str],
+        budget: Optional[float],
+    ) -> Invocation:
+        """Build a headless Pi JSON invocation."""
+        argv = [
+            *self.parts,
+            '--mode',
+            'json',
+            '--no-approve',
+            '--no-extensions',
+            '--no-skills',
+        ]
+        skills = sorted((self.node.node_dir / 'skills').glob('*/SKILL.md'))
+        for skill in skills:
+            argv += ['--skill', str(skill)]
+        argv += ['--no-prompt-templates', '--no-themes']
+        if model:
+            argv += ['--model', model]
+        if effort:
+            argv += ['--thinking', effort]
+        if mode == 'resume':
+            argv += ['--session', session]
+        elif mode == 'fork':
+            argv += ['--fork', session]
+        if prompt.startswith('-'):
+            prompt = f'\n{prompt}'
+        argv += ['-p', prompt]
+        env = {
+            'PI_CODING_AGENT_SESSION_DIR': str(self.node.node_dir / '.pi' / 'sessions')
+        }
+        return Invocation(
+            agent=self.name,
+            argv=tuple(argv),
+            cwd=self.node.worktree,
+            env=env,
+            session=session,
+        )
+
+    def _transcript(self: PiAgent, session: str) -> Optional[pathlib.Path]:
+        """Return the newest matching node-local Pi session log."""
+        sessions_dir = self.node.node_dir / '.pi' / 'sessions'
+        found = sorted(sessions_dir.glob(f'*_{session}.jsonl'))
+        if found:
+            return found[-1]
+        return None
