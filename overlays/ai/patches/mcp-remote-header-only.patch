+const HEADER_ONLY_INVALID = 'agent-http-header-bridge: invalid invocation'
+const HEADER_ONLY_CREDENTIAL = 'agent-http-header-bridge: credential unavailable'
+const HEADER_ONLY_TRANSPORT = 'agent-http-header-bridge: transport failed'
+
+let headerOnlyFailed = false
+
+function failHeaderOnly(message: string): never {
+  if (!headerOnlyFailed) {
+    headerOnlyFailed = true
+    writeSync(2, `${message}\n`)
+  }
+  process.exit(1)
+}
+
+function installHeaderOnlyErrorHandlers() {
+  process.on('uncaughtException', () => failHeaderOnly(HEADER_ONLY_TRANSPORT))
+  process.on('unhandledRejection', () => failHeaderOnly(HEADER_ONLY_TRANSPORT))
+}
+
+function parseHeaderOnlyArgs(args: string[]) {
+  if (
+    args.length !== 7 ||
+    args[1] !== '--header' ||
+    args[3] !== '--header-only' ||
+    args[4] !== '--transport' ||
+    args[5] !== 'http-only' ||
+    args[6] !== '--silent'
+  ) {
+    failHeaderOnly(HEADER_ONLY_INVALID)
+  }
+
+  let serverUrl: URL
+  try {
+    serverUrl = new URL(args[0])
+  } catch {
+    failHeaderOnly(HEADER_ONLY_INVALID)
+  }
+  if (serverUrl.protocol !== 'https:' || !serverUrl.hostname || serverUrl.username || serverUrl.password) {
+    failHeaderOnly(HEADER_ONLY_INVALID)
+  }
+
+  const headerArgument = args[2]
+  const headerMatch = /^([!#$%&'*+\-.^_`|~0-9A-Za-z]+): \$\{([A-Za-z_][A-Za-z0-9_]*)\}$/.exec(headerArgument)
+  if (!headerMatch || headerMatch[0] !== headerArgument) {
+    failHeaderOnly(HEADER_ONLY_INVALID)
+  }
+
+  const envName = headerMatch[2]
+  const headerValue = process.env[envName]
+  delete process.env[envName]
+  if (!headerValue || /[\u0000-\u001f\u007f]/.test(headerValue)) {
+    failHeaderOnly(HEADER_ONLY_CREDENTIAL)
+  }
+
+  const headers = Object.create(null) as Record<string, string>
+  headers[headerMatch[1]] = headerValue
+  return { serverUrl, headers }
+}
+
+const headerOnlyFetch: typeof fetch = (input, init) => fetch(input, { ...init, redirect: 'error' })
+
+async function runHeaderOnlyProxy(args: string[]) {
+  const { serverUrl, headers } = parseHeaderOnlyArgs(args)
+  const localTransport = new StdioServerTransport()
+  const remoteTransport = new StreamableHTTPClientTransport(serverUrl, {
+    fetch: headerOnlyFetch,
+    requestInit: { headers, redirect: 'error' },
+    reconnectionOptions: {
+      initialReconnectionDelay: 1000,
+      maxReconnectionDelay: 1000,
+      reconnectionDelayGrowFactor: 1,
+      maxRetries: 0,
+    },
+  })
+
+  mcpProxy({
+    transportToClient: localTransport,
+    transportToServer: remoteTransport,
+    onTransportError: () => failHeaderOnly(HEADER_ONLY_TRANSPORT),
+  })
+
+  await remoteTransport.start()
+  await localTransport.start()
+  setupSignalHandlers(async () => {
+    await Promise.allSettled([remoteTransport.close(), localTransport.close()])
+  })
+}
+
