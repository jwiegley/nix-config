#!/usr/bin/env bash

set -euo pipefail

run_switch=true
run_brew=true

usage() {
    cat <<'EOF'
usage: update-agents [--no-switch] [--no-brew]

Update ai-nix tools, commit and push ai-nix, update this flake's ai-nix lock,
and optionally switch the host.

Options:
  --no-switch  Skip the final NixOS/nix-darwin switch
  --no-brew    Skip the background Homebrew update/upgrade
EOF
}

while (($#)); do
    case $1 in
    --no-switch)
        run_switch=false
        ;;
    --no-brew)
        run_brew=false
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    *)
        echo "update-agents: unknown option: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
    shift
done

if [[ -d /etc/nixos ]]; then
    config_dir=/etc/nixos
else
    config_dir=${NIX_CONFIG_DIR:-$HOME/src/nix}
fi

ai_nix_dir=${AI_NIX_DIR:-$HOME/src/ai-nix}
brew_pid=

if [[ ! -f $ai_nix_dir/flake.nix ]]; then
    echo "update-agents: ai-nix checkout not found at $ai_nix_dir" >&2
    echo "Set AI_NIX_DIR or clone https://github.com/jwiegley/ai-nix there." >&2
    exit 1
fi

if [[ $run_brew == true ]] && command -v brew >/dev/null 2>&1; then
    (
        brew update
        brew upgrade --greedy --yes
    ) &>/tmp/brew.log &
    brew_pid=$!
fi

git_pull_clean() {
    local repo=$1
    if [[ -n $(git -C "$repo" status --porcelain) ]]; then
        echo "update-agents: refusing to auto-update dirty repo: $repo" >&2
        exit 1
    fi
    git -C "$repo" pull --ff-only
}

commit_if_changed() {
    local repo=$1
    local message=$2

    if [[ -z $(git -C "$repo" status --porcelain) ]]; then
        return 1
    fi

    git -C "$repo" add -A
    git -C "$repo" commit -m "$message"
    return 0
}

commit_and_push_if_changed() {
    local repo=$1
    local message=$2

    if commit_if_changed "$repo" "$message"; then
        git -C "$repo" push
    fi
}

with_nixos_build_lock() {
    local lock=/etc/nixos/.nixos-build

    for _ in {1..60}; do
        if [[ ! -e $lock ]]; then
            sudo touch "$lock"
            trap 'sudo rm -f /etc/nixos/.nixos-build' RETURN
            "$@"
            sudo rm -f "$lock"
            trap - RETURN
            return
        fi
        sleep 10
    done

    echo "update-agents: $lock still exists after 10 minutes" >&2
    exit 1
}

git_pull_clean "$ai_nix_dir"
git_pull_clean "$config_dir"

(
    cd "$ai_nix_dir"
    nix flake update
    python "$config_dir/bin/update-overlay" \
        --only-ai-nix \
        --all \
        --ai-nix-dir "$ai_nix_dir" \
        --no-ai-nix-advice
    nix run .#format
)

commit_and_push_if_changed "$ai_nix_dir" "Update AI tools"

(
    cd "$ai_nix_dir"
    nix run .#check
)

(
    cd "$config_dir"
    nix flake update ai-nix
)

commit_if_changed "$config_dir" "Update AI agents" || true

if [[ $run_switch == true ]]; then
    if [[ -d /etc/srp-next ]]; then
        with_nixos_build_lock sudo nixos-rebuild switch --flake "$config_dir#ovh-vps"
    elif [[ -d /etc/nixos ]]; then
        with_nixos_build_lock sudo nixos-rebuild switch --flake "$config_dir#vulcan"
    else
        u switch
    fi
fi

git -C "$config_dir" push

if [[ -n $brew_pid ]]; then
    wait "$brew_pid"
fi
