#!/usr/bin/env bash

if [[ -d /etc/nixos ]]; then
    cd /etc/nixos || exit
else
    cd ~/src/nix || exit
fi

(
    brew update
    brew upgrade --greedy --yes
) &>/tmp/brew.log &

nix flake update --commit-lock-file llm-agents

if [[ -d /etc/srp-next ]]; then
    sudo nixos-rebuild switch --flake '.#ovh-vps'
elif [[ -d /etc/nixos ]]; then
    sudo nixos-rebuild switch --flake '.#vulcan'
else
    u switch
fi

git push

wait
