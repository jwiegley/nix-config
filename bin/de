#!/usr/bin/env bash

set -e

# I use this to keep build products in a separate directory tree.
PRODUCTS=""
if [[ -d $HOME/Products ]]; then
    case $PWD in
    "$HOME/src" | "$HOME/src"/*)
        PRODUCTS="$HOME/Products${PWD#"$HOME/src"}"
        ;;
    "$HOME/hera" | "$HOME/hera"/*)
        PRODUCTS="$HOME/Products/hera${PWD#"$HOME/hera"}"
        ;;
    *)
        PRODUCTS=$PWD
        ;;
    esac
    echo "There is a ~/Products directory"
fi

if [[ "$1" == "--no-cache" ]]; then
    shift 1
    echo "Disabling use of the Nix cache"
fi

NIXOPTS=(--cores 2 -j4)
NIXOPTS_MORE=()

if [[ -f flake.nix ]]; then
    echo "Using the package set for <darwin>"
    # NIXOPTS_MORE+=(--override-input nixpkgs nixpkgs --inputs-from ~/src/nix)
else
    echo "Using the package set for <darwin>"
    NIXOPTS_MORE+=(--arg pkgs '(import<darwin>{}).pkgs')
fi

if [[ -n ${BUILDER+x} ]]; then
    NIXOPTS+=(--option builders "ssh-ng://${BUILDER}")
    echo "Using builder: ssh-ng://${BUILDER}"
fi

if [[ -n "$PRODUCTS" && (-f Cargo.toml || -f ../Cargo.toml) ]]; then
    cargo_target_dir=$PRODUCTS/target
    mkdir -p "$cargo_target_dir"
    [[ -e "$cargo_target_dir/.metadata_never_index" ]] ||
        : >"$cargo_target_dir/.metadata_never_index"
fi

if [[ ! -f .envrc ]]; then
    cat >.envrc <<'EOF'
keep_vars() {
    local k v
    DIRENV_kept=
    for k in "$@"; do
        [[ -v $k ]] || continue
        v=${!k}
        DIRENV_kept="$DIRENV_kept"$(printf "%s=%s\000" "$k" "$v" | base64)
    done
}

reset_kept() {
    : ${DIRENV_kept?No environment stored. Missing keep_except()?}
    echo "$DIRENV_kept" | base64 -d | while IFS= read -r -d '' V; do
        echo "export ${V%%=*}='${V#*=}'"
    done
    unset DIRENV_kept
}

keep_vars                                       \
    ALTERNATE_EDITOR                            \
    EDITOR                                      \
    EMACS_SERVER_FILE                           \
    GIT_PROMPT_EXECUTABLE                       \
    GH_ACCOUNT                                  \
    ITERM_SESSION_ID                            \
    NIX_PATH                                    \
    PERSONA                                     \
    PROMPT                                      \
    RPROMPT                                     \
    SECURITYSESSIONID                           \
    SSH_AUTH_SOCK                               \
    SSL_CERT_FILE                               \
    STARSHIP_CONFIG                             \
    STARSHIP_SESSION_KEY                        \
    STARSHIP_SHELL                              \
    TERM                                        \
    TERM_SESSION_ID                             \
    TMPDIR                                      \
    XDG_DATA_DIRS                               \
    __GIT_PROMPT_DIR

source <(direnv apply_dump .envrc.cache)
source <(reset_kept)

watch_file .envrc
watch_file .envrc.cache
watch_file default.nix
EOF

    [[ -f package.nix ]] && echo "watch_file package.nix" >>.envrc
    [[ -f shell.nix ]] && echo "watch_file shell.nix" >>.envrc

    if [[ -n "$PRODUCTS" ]]; then
        if [[ -f package.yaml ||
            -n "$(find . -maxdepth 1 -name '*.cabal')" ]]; then
            cat >>.envrc <<EOF

export CABAL_BUILDDIR=$PRODUCTS/dist
EOF
        fi

        if [[ -f Cargo.toml || -f ../Cargo.toml ]]; then
            # uname -m reports "arm64" on Apple Silicon, but Cargo's target
            # triple uses "aarch64". Translate so the per-triple PATH entries
            # (used only for --target builds) actually resolve.
            arch_triple=$(uname -m)-apple-darwin
            if [[ "$arch_triple" == "arm64-apple-darwin" ]]; then
                arch_triple="aarch64-apple-darwin"
            fi
            cat >>.envrc <<EOF

export CARGO_TARGET_DIR=$cargo_target_dir
export CARGO_HOME=\$CARGO_TARGET_DIR/.cargo-home
# export RUSTUP_HOME=\$CARGO_TARGET_DIR/.rustup-home
# export RUSTUP_TOOLCHAIN=1.60.0-x86_64-apple-darwin
# export RUSTC_WRAPPER=$(which sccache)
export PATH=\$PATH:\$CARGO_HOME/bin
export PATH=\$PATH:\$CARGO_TARGET_DIR/debug
export PATH=\$PATH:\$CARGO_TARGET_DIR/release
export PATH=\$PATH:\$CARGO_TARGET_DIR/${arch_triple}/debug
export PATH=\$PATH:\$CARGO_TARGET_DIR/${arch_triple}/release
EOF
        fi
    fi
fi

export NIXPKGS_ALLOW_UNFREE=1
export NIXPKGS_ALLOW_BROKEN=1

# Keep prompt/session state out of the cache; the generated .envrc preserves
# each caller's live values across both load and unload.
SCRIPT="unset         \
    ALTERNATE_EDITOR  \
    EDITOR            \
    EMACS_SERVER_FILE \
    ITERM_SESSION_ID  \
    NIX_PATH          \
    PROMPT            \
    RPROMPT           \
    SECURITYSESSIONID \
    SSH_AUTH_SOCK     \
    SSL_CERT_FILE     \
    STARSHIP_CONFIG   \
    STARSHIP_SESSION_KEY \
    STARSHIP_SHELL    \
    TERM              \
    TERM_SESSION_ID;  \
if [[ -f .env ]]; then set -a; source .env; set +a; fi; \
direnv dump > .envrc.cache"

if [[ -f flake.nix ]]; then
    nix develop "${NIXOPTS[@]}" "$@" "${NIXOPTS_MORE[@]}" -c bash -c "$SCRIPT"
elif [[ -f shell-new.nix ]]; then
    nix-shell shell-new.nix "${NIXOPTS[@]}" "$@" -Q "${NIXOPTS_MORE[@]}" --run "$SCRIPT"
else
    nix-shell "${NIXOPTS[@]}" "$@" -Q "${NIXOPTS_MORE[@]}" --run "$SCRIPT"
fi

direnv reload
