#!/usr/bin/env bash
#
# persona — Switch development identity across Claude Code, GitHub CLI, and git
#
# Usage:
#   persona <name>       Switch to a persona (use via shell function wrapper)
#   persona --status     Show current persona
#   persona --list       List available personas
#   persona --env        Output current persona's exports (for shell init)
#

set -euo pipefail

PERSONA_DIR="${HOME}/.config/persona"
CURRENT_FILE="${PERSONA_DIR}/current"
GIT_PERSONA_CONFIG="${HOME}/.config/git/persona.gitconfig"

die() { echo "persona: $*" >&2; exit 1; }

# Validate persona name contains only safe characters
validate_name() {
    [[ "$1" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Invalid persona name: '$1'"
}

usage() {
    cat >&2 <<'EOF'
Usage: persona <name>     Switch to a persona
       persona --status   Show current persona
       persona --list     List available personas
       persona --env      Output current persona's exports

Personas are defined in ~/.config/persona/<name>.conf
EOF
    exit 1
}

# Output eval-safe exports to stdout
emit_exports() {
    local name="$1" claude_dir="$2"
    printf 'export PERSONA=%q;\n' "$name"
    printf 'export CLAUDE_CONFIG_DIR=%q;\n' "$claude_dir"
}

list_personas() {
    local current=""
    [[ -f "$CURRENT_FILE" ]] && current=$(cat "$CURRENT_FILE")

    for conf in "${PERSONA_DIR}"/*.conf; do
        [[ -f "$conf" ]] || continue
        local name
        name=$(basename "$conf" .conf)
        if [[ "$name" == "$current" ]]; then
            echo "* ${name} (active)" >&2
        else
            echo "  ${name}" >&2
        fi
    done
}

show_status() {
    if [[ -f "$CURRENT_FILE" ]]; then
        local current
        current=$(cat "$CURRENT_FILE")
        local conf="${PERSONA_DIR}/${current}.conf"
        if [[ -f "$conf" ]]; then
            local CLAUDE_DIR="" GH_USER="" GIT_NAME="" GIT_EMAIL=""
            local GIT_SIGNING_KEY="" GITHUB_USER=""
            # shellcheck source=/dev/null
            source "$conf"
            cat >&2 <<EOF
Active persona: ${current}
  Claude:   ${CLAUDE_DIR}
  GitHub:   ${GH_USER} (gh auth)
  Git:      ${GIT_NAME} <${GIT_EMAIL}>
  Signing:  ${GIT_SIGNING_KEY}
  Hub user: ${GITHUB_USER}
EOF
        else
            echo "Active persona: ${current} (config missing!)" >&2
        fi
    else
        echo "No active persona" >&2
    fi
}

output_env() {
    local name=""
    if [[ -f "$CURRENT_FILE" ]]; then
        name=$(cat "$CURRENT_FILE")
    else
        name="personal"
    fi
    local conf="${PERSONA_DIR}/${name}.conf"
    if [[ -f "$conf" ]]; then
        local CLAUDE_DIR="" GH_USER="" GIT_NAME="" GIT_EMAIL=""
        local GIT_SIGNING_KEY="" GITHUB_USER=""
        # shellcheck source=/dev/null
        source "$conf"
        emit_exports "$name" "${CLAUDE_DIR}"
    else
        echo "persona: config not found for '${name}'" >&2
    fi
}

switch_persona() {
    local name="$1"
    validate_name "$name"
    local conf="${PERSONA_DIR}/${name}.conf"

    [[ -f "$conf" ]] || die "Unknown persona '${name}'. Use --list to see available personas."

    # Source persona config
    local CLAUDE_DIR="" GH_USER="" GIT_NAME="" GIT_EMAIL=""
    local GIT_SIGNING_KEY="" GITHUB_USER=""
    # shellcheck source=/dev/null
    source "$conf"

    # 1. Update ~/.claude symlink (ln -sfn is atomic on macOS)
    if [[ -n "$CLAUDE_DIR" && -d "$CLAUDE_DIR" ]]; then
        ln -sfn "$CLAUDE_DIR" "${HOME}/.claude"
        echo "Claude: -> ${CLAUDE_DIR}" >&2
    fi

    # 2. Write writable git persona config (overrides home-manager defaults)
    mkdir -p "$(dirname "$GIT_PERSONA_CONFIG")"
    {
        echo "# Auto-generated by persona script — do not edit manually"
        echo "[user]"
        [[ -n "$GIT_NAME" ]] && echo "    name = ${GIT_NAME}"
        [[ -n "$GIT_EMAIL" ]] && echo "    email = ${GIT_EMAIL}"
        if [[ -n "$GIT_SIGNING_KEY" ]]; then
            echo "    signingkey = ${GIT_SIGNING_KEY}"
            echo "[commit]"
            echo "    gpgsign = true"
        else
            echo "[commit]"
            echo "    gpgsign = false"
        fi
        echo "[github]"
        [[ -n "$GITHUB_USER" ]] && echo "    user = ${GITHUB_USER}"
    } > "$GIT_PERSONA_CONFIG"
    echo "Git:    ${GIT_NAME} <${GIT_EMAIL}>" >&2

    # 3. Switch GitHub CLI account
    if [[ -n "$GH_USER" ]] && command -v gh &>/dev/null; then
        gh auth switch --user "$GH_USER" 2>/dev/null || true
        echo "GitHub: ${GH_USER}" >&2
    fi

    # 4. Save current persona
    mkdir -p "$PERSONA_DIR"
    echo "$name" > "$CURRENT_FILE"
    echo "Switched to persona: ${name}" >&2

    # 5. Output eval-able exports to stdout
    emit_exports "$name" "${CLAUDE_DIR:-}"
}

# Main
case "${1:-}" in
    --status|-s)  show_status ;;
    --list|-l)    list_personas ;;
    --env|-e)     output_env ;;
    --help|-h|"") usage ;;
    *)            switch_persona "$1" ;;
esac
