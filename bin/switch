#!/usr/bin/env bash

set -eou pipefail

if [[ "$(uname -s)" == "Darwin" ]]; then
    exec u switch
elif [[ -d /etc/nixos ]]; then
    cd /etc/nixos
    exec sudo nixos-rebuild switch --flake ".#$(hostname)"
elif [[ -d ~/.config/home-manager ]]; then
    cd ~/.config/home-manager
    exec nix run home-manager/master -- switch
else
    exec u "$(hostname)" switch
fi
