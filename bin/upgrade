#!/usr/bin/env bash

if [[ "$(uname -s)" == "Darwin" ]]; then
    sudo /bin/launchctl limit maxfiles 524288 524288
    ulimit -n 65536
fi

HOST=${1:-$(hostname)}

if [[ $HOST =~ [Vv]ulcan ]]; then
    HOST=vulcan
elif [[ $HOST =~ [Hh]era ]]; then
    HOST=hera
elif [[ $HOST =~ [Cc]lio ]]; then
    HOST=clio
else
    echo "upgrade script does not recognize hostname '$HOST'"
    exit 1
fi

case $HOST in
hera)
    ulimit -n 65536
    cd ~/src/nix || exit
    update-and-pull
    ./bin/update-agents --no-switch --no-brew
    u hera update
    python bin/update-overlay --no-ai-nix --all
    ./build system
    u hera upgrade-tasks sign # check
    # notify "Nix on Hera upgraded"
    ;;

clio)
    ulimit -n 65536
    cd ~/src/nix || exit
    ./build system
    u clio upgrade-tasks # check
    # notify "Nix on Clio upgraded"
    ;;

*)
    echo "Unrecognized hostname: $1"
    exit 1
    ;;
esac

echo '┌────────────────────────────────────────────────────────────────────────────┐'
echo '│ >>> upgrade .config/projects                                               │'
echo '└────────────────────────────────────────────────────────────────────────────┘'

### Coq projects

echo ~/src/category-theory/master
(
    cd ~/src/category-theory/master || exit
    echo ~/src/category-theory/master
    source .envrc
    nix develop -c echo hello
) >/tmp/category-theory-build.log 2>&1

if [[ $? = 0 ]]; then echo "done"; else echo "FAIL"; fi

echo ~/src/ltl/coq
(
    cd ~/src/ltl/coq || exit
    source .envrc
    nix develop -c echo hello
) >/tmp/ltl-coq-build.log 2>&1

if [[ $? = 0 ]]; then echo "done"; else echo "FAIL"; fi

### Haskell projects

echo ~/src/notes/haskell
(
    cd ~/src/notes/haskell || exit
    echo ~/src/notes/haskell
    source .envrc
    nix develop -c echo hello
    cabal v2-update
    cabal v2-configure --disable-tests \
        --disable-profiling --disable-executable-profiling
) >/tmp/notes-haskell-build.log 2>&1

if [[ $? = 0 ]]; then echo "done"; else echo "FAIL"; fi

echo ~/src/org-jw
(
    cd ~/src/org-jw || exit
