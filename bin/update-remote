#!/usr/bin/env bash

set -euo pipefail

# Run each command in its own tmux pane within the current window
tmux split-window "ssh clio 'upgrade clio' ; echo 'clio done — press Enter' ; read"
tmux split-window "ssh vulcan '(cd /etc/nixos ; nix flake update --commit-lock-file && sudo nixos-rebuild switch --flake \".#vulcan\")' ; echo 'vulcan done — press Enter' ; read"
tmux split-window "ssh vps '(cd /etc/nixos ; nix flake update --commit-lock-file && sudo nixos-rebuild switch --flake \".#ovh-vps\")' ; echo 'vulcan done — press Enter' ; read"
tmux select-layout even-vertical

# Run the last one in the current pane

HOSTS=(
    # andoria-02
    # andoria-04
    # andoria-06
    andoria-08
    # andoria-09
    # andoria-11
    # andoria-12
    # andoria-13
    # andoria-14
    # andoria-15
    # andoria-16

    # andoria-t1
    # andoria-t2

    # andoria-d03d
    # andoria-c9a8

    # delphi-1765
    # delphi-17bb
    # delphi-17cf

    git-ai
)

# All of the hosts share the same home directory via NFS
ssh andoria-08 "(cd /home/jwiegley/.config/home-manager ; nix flake update --commit-lock-file)"
ssh git-ai "(cd /home/jwiegley/.config/home-manager ; nix flake update --commit-lock-file)"

for host in ${HOSTS[@]}
do
    ssh $host nix run home-manager/master switch
done
